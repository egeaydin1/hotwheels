# ── Application ────────────────────────────────────────────────────────────────
# Full public URL of your site (no trailing slash)
NEXTAUTH_URL=https://yourdomain.com

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME

# Port the app listens on (default: 3000)
PORT=3000

# ── Database ───────────────────────────────────────────────────────────────────
DB_NAME=hotwheels
DB_USER=hw_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── MinIO (object storage) ─────────────────────────────────────────────────────
MINIO_USER=minio_admin
MINIO_PASSWORD=CHANGE_ME_STRONG_PASSWORD
STORAGE_BUCKET=hotwheels
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=${MINIO_USER}
STORAGE_SECRET_KEY=${MINIO_PASSWORD}

# ── Seed ───────────────────────────────────────────────────────────────────────
# Set to "true" on FIRST boot to import the Hot Wheels catalog (~10k cars).
# Set back to "false" after first run to avoid re-seeding on restarts.
SEED_DATA=false
